# Force npm to use a flat structure for node_modules
# This helps prevent duplication in monorepos
shamefully-hoist=true

# Keep a single lockfile at the root of the project
# This ensures consistent dependency versions across all microservices
lockfile-directory=../../

# Auto-install peer dependencies if they are missing
# Reduces 'missing peer dependency' warnings during development
auto-install-peers=true

# Network resilience — retries on transient ECONNRESET (parallel Docker builds hit this)
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
