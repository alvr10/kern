# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
GATEWAY_PORT=3000
ADMIN_PORT=3009

# ─── Supabase / Postgres ──────────────────────────────────────────────────────
# Pooler connection (port 6543) — used for normal queries
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true
# Direct connection (port 5432) — used for migrations
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── MongoDB (Docker container) ───────────────────────────────────────────────
MONGO_ROOT_USER=kern
MONGO_ROOT_PASS=kernpass
MONGO_DB=kern
# This URI is used by services to connect to the mongo container inside Docker
MONGODB_URI=mongodb://kern:kernpass@mongodb:27017/kern?authSource=admin

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=change-me-in-production
