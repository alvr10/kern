    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.8.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
