{
  "$schema": "https://v2-9-18.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {
      "cache": true
    },
    "lint:check": {
      "cache": true
    },
    "format": {
      "cache": true
    },
    "format:check": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prisma:generate": {
      "cache": true,
      "outputs": ["node_modules/.prisma/client/**"]
    }
  }
}
